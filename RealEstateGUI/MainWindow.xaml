<Window x:Class="RealEstateGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RealEstateGUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"></ColumnDefinition>
                <ColumnDefinition Width="2*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <ListView x:Name="nevek" Grid.Column="0"></ListView>
            <StackPanel Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <Label Margin="10,0,50,0">Eladó neve:</Label>
                    <Label>asd</Label>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Margin="10,0,50,0">Eladó telefonszáma:</Label>
                    <Label>213</Label>
                </StackPanel>
                <Button Margin="10,0,10,0">Hirdetések betöltése</Button>
                <StackPanel Orientation="Horizontal">
                    <Label Margin="10,0,50,0">Hirdetések száma:</Label>
                    <Label>1</Label>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
